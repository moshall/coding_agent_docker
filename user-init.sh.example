#!/usr/bin/env bash
# ==================================================================
# user-init.sh - user customization hook
#
# Purpose:
#   Install personal packages/tools that are not part of base image.
#   This script runs on every container start as root.
#
# Usage:
#   cp /data/coding-agent/user-init.sh.example /data/coding-agent/user-init.sh
#   Edit /data/coding-agent/user-init.sh and uncomment what you need.
# ==================================================================

set -euo pipefail

# System tools
# apt-get update && apt-get install -y -q vim tree htop jq

# Node global packages
# npm install -g typescript ts-node eslint prettier

# Python packages
# pip3 install --break-system-packages jupyterlab notebook

# Shell customization
# cat >> /home/node/.bashrc <<'BASHRC'
# alias ll='ls -alF'
# export EDITOR=vim
# BASHRC

echo "[user-init] done."

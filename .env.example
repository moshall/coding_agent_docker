# ================================================================
# Coding Agent - Environment Configuration
# Copy this file to .env and fill in your own values.
# This file can contain secrets. Do not commit .env to git.
#
# docker-compose.yml 已列出全部注入项；除各 *_API_KEY / TOKEN 等密钥外，
# 下列非密钥行均为可直接使用的预设，按需修改即可。
# ================================================================

# ---------------- Paths ----------------
# Root directory for persistent host data (same path on host and in container).
# 推荐 /data/...、/opt/... 等；若 1Panel 使用 /root/...：镜像启动时会把「容器内」/root 改为 0711，
# 以便 node(1000) 进入子目录（不可列举 /root；若仍失败请检查宿主机绑定目录权限）。
DATA_ROOT=/data/coding-agent

# ---------------- Container Basics ----------------
CONTAINER_NAME=coding-agent
TZ=Asia/Shanghai
NODE_ENV=development
# Optional runtime package switch.
# Leave unset/empty to keep disabled.
# Set to true to install Go at container startup.
# Once enabled, the choice is remembered under DATA_ROOT/software/bootstrap/install-go-runtime.
# To fully disable later, clear the env var and remove that marker file.
# INSTALL_GO_RUNTIME=true
# Optional runtime package switch.
# Leave unset/empty to keep disabled.
# Set to true to install build-essential at container startup.
# Once enabled, the choice is remembered under DATA_ROOT/software/bootstrap/install-build-essential.
# To fully disable later, clear the env var and remove that marker file.
# INSTALL_BUILD_ESSENTIAL=true

# ---------------- Claude Code ----------------
# Required for Claude CLI usage.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx
# Optional proxy endpoint.
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# ---------------- Codex ----------------
# Required for Codex CLI usage.
OPENAI_API_KEY=sk-xxxxxxxxxx
# Optional proxy endpoint, must support Responses API.
# OPENAI_BASE_URL=https://your-proxy.example.com/v1
# Optional model override.
# CODEX_MODEL=gpt-5-codex

# ---------------- Gemini CLI ----------------
GEMINI_API_KEY=AIzaxxxxxxxxxx

# ---------------- Task Master ----------------
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxx
# PERPLEXITY_API_KEY=pplx-xxxxxxxxxx
TASKMASTER_MAIN_PROVIDER=anthropic
TASKMASTER_MAIN_MODEL=claude-sonnet-4-20250514
# TASKMASTER_RESEARCH_PROVIDER=perplexity
# TASKMASTER_RESEARCH_MODEL=sonar-pro
# TASKMASTER_FALLBACK_PROVIDER=anthropic
# TASKMASTER_FALLBACK_MODEL=claude-haiku-4-5-20251001

# ---------------- GitHub CLI ----------------
# GH_TOKEN=ghp_xxxxxxxxxx

# ---------------- Tailscale ----------------
# TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxx
# TAILSCALE_HOSTNAME=coding-agent

# ---------------- Ports ----------------
PORT_CC_CONNECT=8080
PORT_RALPH=3000
# CloudCLI (claudecodeui) Web UI — https://github.com/siteboon/claudecodeui
PORT_CLOUDCLI=3001
PORT_DEV=9000

# ---------------- CloudCLI Web UI ----------------
# Set to false to skip starting cloudcli at container boot.
# CLOUDCLI_ENABLE=true
# Listening port inside container (keep in sync with PORT_CLOUDCLI mapping).
# CLOUDCLI_PORT=3001
# Workspace root visible to CloudCLI project manager.
# Keep this as /home/node to allow managing /home/node, /home/node/project, /home/node/projects.
# CLOUDCLI_WORKSPACES_ROOT=/home/node
# Default path prefilled when creating a workspace (if CloudCLI version supports it).
# CLOUDCLI_DEFAULT_WORKSPACE_PATH=/home/node/project

# ---------------- Superpowers (obra/superpowers) ----------------
# Claude Code: https://github.com/obra/superpowers#claude-code-official-marketplace
# 默认开启（与 docker-compose 中 ${...:-true} 一致）；设为 false 可跳过出网安装官方插件。
SUPERPOWERS_CLAUDE_PLUGIN_ENABLE=true
#
# Codex: ~/.codex/superpowers + ~/.agents/skills/superpowers（由 entrypoint 自动处理，见 .codex/INSTALL.md）
#
# 持久化只需挂载 DATA_ROOT；额外工作区（例如与宿主机某目录同路径）请在 docker-compose.yml 里自行增加 volumes。

# ---------------- Source build (docker-compose.dev.yml) ----------------
# Tool version channel:
# - baseline: use versions pinned in docker/npm-required.txt and docker/python-requirements.txt
# - latest: resolve latest upstream versions for selected tools during build
# TOOL_VERSION_CHANNEL=baseline
#
# Optional overrides for selected tools (works in both baseline/latest channel):
# CLAUDE_CODE_VERSION=2.1.80
# CODEX_VERSION=0.116.0
# CLOUDCLI_VERSION=1.25.2
# CCMAN_VERSION=3.3.23
# GH_VERSION=2.79.0
#
# cc-connect ref strategy:
# - CC_CONNECT_VERSION_CHANNEL=baseline + empty CC_CONNECT_GIT_REF => default branch HEAD
# - CC_CONNECT_VERSION_CHANNEL=latest  + empty CC_CONNECT_GIT_REF => latest upstream v* tag
# - CC_CONNECT_GIT_REF=v1.0.0 (or branch) => fixed source ref
# CC_CONNECT_VERSION_CHANNEL=baseline
# 固定 cc-connect 的 git 分支或 tag（可选，默认同仓库默认分支 HEAD）
# CC_CONNECT_GIT_REF=

# ---------------- Docker Image ----------------
DOCKER_IMAGE=ghcr.io/moshall/coding_agent_docker:latest

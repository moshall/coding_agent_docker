# ================================================================
# 1Panel 部署用：复制为同目录下的 .env 后编辑
# 与仓库根目录 .env.example 相同，仅 DATA_ROOT 默认改为 1Panel 常见路径
# ================================================================

# 持久化根目录（宿主机须存在且建议 chown -R 1000:1000）
DATA_ROOT=/opt/1panel/apps/coding_agent_docker

CONTAINER_NAME=coding-agent
TZ=Asia/Shanghai
NODE_ENV=development

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
TASKMASTER_MAIN_PROVIDER=anthropic
TASKMASTER_MAIN_MODEL=claude-sonnet-4-20250514

PORT_CC_CONNECT=8080
PORT_RALPH=3000
PORT_CLOUDCLI=3001
PORT_DEV=9000
CLOUDCLI_WORKSPACES_ROOT=/home/node
CLOUDCLI_DEFAULT_WORKSPACE_PATH=/home/node/project

SUPERPOWERS_CLAUDE_PLUGIN_ENABLE=true

# 镜像名写在 docker-compose.yml 的 image 行（1Panel 拉取镜像时不替换 ${DOCKER_IMAGE}）
# 其余可选变量见仓库根目录 .env.example（ANTHROPIC_BASE_URL、TAILSCALE、GH_TOKEN 等）
